#!/bin/sh
#
# deploy-check -- quick stale-build/deployment sanity check for darwin-aarch64.
set -u

SELF="$0"
while [ -h "$SELF" ]; do
    dir="$(cd "$(dirname "$SELF")" && pwd)"
    SELF="$(readlink "$SELF")"; case "$SELF" in /*) ;; *) SELF="$dir/$SELF" ;; esac
done
HERE="$(cd "$(dirname "$SELF")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
: "${AROS_HOST_CONF:=$HOME/Library/Application Support/AROS/aros-host.conf}"
: "${AROS_APP:=$ROOT/build/Macaros.app}"

find_bootd() {
    if [ -n "${AROS_CTL_BOOTD:-}" ]; then printf '%s\n' "$AROS_CTL_BOOTD"; return; fi
    best=""; bt=0
    for d in \
        "${BUILD:-/tmp/arosbuild}/bin/darwin-aarch64/AROS/boot/darwin" \
        "$ROOT/build/AROS/boot/darwin" \
        /private/tmp/claude-*/*/*/scratchpad/arosbuild/bin/darwin-aarch64/AROS/boot/darwin \
        /tmp/*/bin/darwin-aarch64/AROS/boot/darwin ; do
        [ -x "$d/AROSBootstrap" ] || continue
        t="$(stat -f %m "$d/AROSBootstrap" 2>/dev/null || echo 0)"
        if [ "$t" -ge "$bt" ]; then bt="$t"; best="$d"; fi
    done
    printf '%s\n' "$best"
}

hash12() {
    [ -f "$1" ] || { printf '%s' "missing"; return; }
    shasum -a 256 "$1" 2>/dev/null | awk '{print substr($1,1,12)}'
}

stamp() {
    [ -e "$1" ] || { printf '%s' "-"; return; }
    stat -f '%Sm' -t '%Y-%m-%d %H:%M:%S' "$1" 2>/dev/null || printf '%s' "-"
}

line() {
    label="$1"; path="$2"
    printf '%-22s %-12s %s  %s\n' "$label" "$(hash12 "$path")" "$(stamp "$path")" "$path"
}

compare() {
    label="$1"; src="$2"; dst="$3"
    sh="$(hash12 "$src")"; dh="$(hash12 "$dst")"
    if [ "$sh" = "$dh" ] && [ "$sh" != "missing" ]; then status="OK"; else status="WARN"; fi
    printf '%-22s %-4s src=%s dst=%s\n' "$label" "$status" "$sh" "$dh"
    [ "$status" = OK ]
}

BOOTD="$(find_bootd)"
if [ -z "$BOOTD" ]; then
    echo "deploy-check: no boot dir found" >&2
    exit 1
fi
AROS="$(cd "$BOOTD/../.." && pwd)"

echo "boot dir: $BOOTD"
echo
echo "host dylibs:"
compare "cocoametal.dylib" "$ROOT/build/cocoametal.dylib" "$HOME/lib/cocoametal.dylib" || true
compare "libpasteboard.dylib" "$ROOT/build/libpasteboard.dylib" "$HOME/lib/libpasteboard.dylib" || true
compare "libcoreaudio.dylib" "$ROOT/build/libcoreaudio.dylib" "$HOME/lib/libcoreaudio.dylib" || true
compare "libbsdsockhost.dylib" "$ROOT/build/libbsdsockhost.dylib" "$HOME/lib/libbsdsockhost.dylib" || true
compare "settings.json" "$ROOT/hosted/cocoametal/settings.json" "$HOME/lib/settings.json" || true

echo
echo "host config:"
if [ -f "$AROS_HOST_CONF" ]; then
    line "aros-host.conf" "$AROS_HOST_CONF"
else
    printf 'MISS                  -            -  %s\n' "$AROS_HOST_CONF"
fi
if [ -f "$HERE/aros-host-conf.sh" ]; then
    eff_hv="$(
        AROS_HOST_CONF="$AROS_HOST_CONF" sh -c '. "$1"; printf "%s" "${AROS_HOST_VOLUME:-}"' sh "$HERE/aros-host-conf.sh"
    )"
    if [ -n "$eff_hv" ]; then
        echo "effective AROS_HOST_VOLUME:"
        printf '%s\n' "$eff_hv" | sed 's/^/  /'
    else
        echo "effective AROS_HOST_VOLUME: <launcher default MacRO/MacRW if unset>"
    fi
fi

echo
echo "app bundle:"
if [ -d "$AROS_APP" ]; then
    APPC="$AROS_APP/Contents"
    line "Macaros.app" "$APPC/Info.plist"
    line "app launcher" "$APPC/MacOS/Macaros"
    compare "app bootstrap" "$BOOTD/AROSBootstrap" "$APPC/MacOS/AROSBootstrap" || true
    compare "app conf" "$BOOTD/AROSBootstrap.conf" "$APPC/MacOS/AROSBootstrap.conf" || true
    compare "app cocoametal" "$ROOT/build/cocoametal.dylib" "$APPC/Frameworks/cocoametal.dylib" || true
    compare "app pasteboard" "$ROOT/build/libpasteboard.dylib" "$APPC/Frameworks/libpasteboard.dylib" || true
    compare "app coreaudio" "$ROOT/build/libcoreaudio.dylib" "$APPC/Frameworks/libcoreaudio.dylib" || true
    compare "app bsdsock" "$ROOT/build/libbsdsockhost.dylib" "$APPC/Frameworks/libbsdsockhost.dylib" || true
    compare "app schema fw" "$ROOT/hosted/cocoametal/settings.json" "$APPC/Frameworks/settings.json" || true
    compare "app schema res" "$ROOT/hosted/cocoametal/settings.json" "$APPC/Resources/settings.json" || true
    compare "app host conf" "$HERE/aros-host-conf.sh" "$APPC/MacOS/aros-host-conf.sh" || true
else
    printf 'SKIP                  -            -  %s\n' "$AROS_APP"
fi

echo
echo "key AROS artifacts:"
line "AROSBootstrap" "$BOOTD/AROSBootstrap"
line "emul-handler" "$BOOTD/L/emul-handler"
line "Cocoa monitor" "$AROS/Storage/Monitors/Cocoa"
line "Devs/Monitors/Cocoa" "$AROS/Devs/Monitors/Cocoa"
compare "Cocoa deployed" "$AROS/Storage/Monitors/Cocoa" "$AROS/Devs/Monitors/Cocoa" || true
line "graphics.library" "$AROS/Libs/graphics.library"
line "intuition.library" "$AROS/Libs/intuition.library"
line "stdc.library" "$AROS/Libs/stdc.library"
line "posixc.library" "$AROS/Libs/posixc.library"
line "muimaster.library" "$AROS/Libs/muimaster.library"
line "ahi.device" "$AROS/Devs/ahi.device"
line "AddAudioModes" "$AROS/C/AddAudioModes"
line "CoreAudio AHI" "$AROS/Devs/AHI/coreaudio.audio"
line "CoreAudio mode" "$AROS/Devs/AudioModes/COREAUDIO"
line "AHISmoke" "$AROS/C/AHISmoke"
line "bsdsocket.library" "$AROS/Libs/bsdsocket.library"
line "socktest" "$AROS/C/socktest"
line "nettest" "$AROS/C/nettest"
line "SetKeyboard" "$AROS/C/SetKeyboard"
# Rust-on-AROS no_std proof ([RS0]/[RS1]): built by hosted/rust/aros-build.sh,
# run by graft/rust-smoke. compare = "is the deployed C: command the one I built?"
compare "RustHello" "$ROOT/build/rust-aros/RustHello" "$AROS/C/RustHello" || true
line "TestLib" "$AROS/C/TestLib"
line "LoadMatrix" "$AROS/C/LoadMatrix"
line "Wanderer" "$AROS/System/Wanderer/Wanderer"

echo
echo "desktop presence:"
for p in \
    "$AROS/Prefs/Zune" \
    "$AROS/Prefs/Wanderer" \
    "$AROS/Fonts" \
    "$AROS/System/Images" \
    "$AROS/Devs/Keymaps" \
    "$AROS/Locale/Catalogs" \
    "$AROS/Prefs/Presets/Themes" \
    "$AROS/System/About" \
    "$AROS/Tools" \
    "$AROS/Utilities" \
    "$AROS/Utilities/Clock" \
    "$AROS/Utilities/MultiView" \
    "$AROS/Utilities/More" ; do
    if [ -e "$p" ]; then
        printf 'OK   %s\n' "$p"
    else
        printf 'MISS %s\n' "$p"
    fi
done

echo
echo "deferred desktop TODO:"
if [ -e "$AROS/Devs/Printers" ]; then
    printf 'OK   %s\n' "$AROS/Devs/Printers"
else
    printf 'TODO %s  (printing/CUPS bridge not wired yet)\n' "$AROS/Devs/Printers"
fi

# x18 staleness guard. macOS clobbers x18 on any signal/kernel entry, so every
# AROS module must be compiled -ffixed-x18 (make.cfg has it, but a make.cfg
# change does NOT invalidate old .o files -- the 2026-07-01 resize-freeze was
# exactly this). Rebuilt-clean modules disassemble to <=4 x18 references
# (context save/stub residue); more means stale pre-flag objects inside.
# Full sweep: deploy-check x18   (scans every module, slower).
echo
echo "x18 staleness (compiled without -ffixed-x18 => wedges under SIGALRM):"
OBJDUMP="${OBJDUMP:-/opt/homebrew/opt/llvm/bin/llvm-objdump}"
if [ -x "$OBJDUMP" ]; then
    X18_LIMIT=4
    x18_fail=0
    if [ "${1:-}" = "x18" ]; then
        X18_SET="$(find "$AROS/Libs" "$AROS/Devs" "$AROS/Classes" "$AROS/L" "$AROS/C" "$BOOTD" -type f 2>/dev/null)"
    else
        X18_SET="$AROS/Libs/graphics.library $AROS/Libs/intuition.library
            $AROS/Libs/layers.library $AROS/Libs/cybergraphics.library
            $AROS/Libs/muimaster.library $AROS/Libs/icon.library
            $AROS/Libs/stdc.library $AROS/Libs/posixc.library
            $AROS/Libs/dos.library $AROS/Libs/keymap.library
            $AROS/Libs/locale.library $AROS/Devs/console.device
            $AROS/Devs/input.device $AROS/L/con-handler $AROS/C/Decoration
            $BOOTD/Libs/exec.library $BOOTD/kernel"
    fi
    for m in $X18_SET; do
        [ -f "$m" ] || continue
        head -c4 "$m" 2>/dev/null | grep -q "$(printf '\177ELF')" || continue
        n="$("$OBJDUMP" -d "$m" 2>/dev/null | grep -cwE 'x18|w18')"
        if [ "${n:-0}" -gt "$X18_LIMIT" ]; then
            printf 'FAIL %-40s %s x18 refs (stale objects -- rebuild it)\n' "${m#$AROS/}" "$n"
            x18_fail=1
        fi
    done
    [ "$x18_fail" = 0 ] && echo "OK   all checked modules <= $X18_LIMIT x18 refs"
else
    echo "SKIP llvm-objdump not found (set OBJDUMP=)"
fi
