#!/bin/bash
#
# aros-ctl — drive hosted AROS in the Cocoa/Metal window from the command line.
#
# Boots AROS with cocoametal's control FIFO ($AROS_CM_CONTROL) so a process with
# no window-server session can puppet it: type, click, move the mouse, capture
# the framebuffer, read logs. Injected input travels the same path as real
# NSEvents (into the AROS keyboard/mouse HIDD), so it faithfully reproduces input
# behaviour. This is both an automation harness and the seed of the embeddable
# library's input/capture API.
#
# Usage:
#   aros-ctl run            boot AROS windowed (background), log to $LOG
#   aros-ctl stop           kill it
#   aros-ctl type TEXT...   type text (lowercase/digits/space/punct; Up=shift)
#   aros-ctl enter          press Return
#   aros-ctl key VK P [MODS] raw key: macOS virtual keycode VK, pressed P (1/0)
#   aros-ctl cmdc           press Command-C
#   aros-ctl cmdv           press Command-V
#   aros-ctl mouse X Y      move pointer to logical X,Y
#   aros-ctl click [BTN]    click (0=left default,1=right,2=middle)
#   aros-ctl button BTN P   raw mouse button BTN pressed P
#   aros-ctl shot [PATH]    screenshot -> PATH (.png via sips, else .ppm)
#   aros-ctl log [N]        last N log lines (default 40)
#   aros-ctl crash          extract crash/alert lines from the log
#   aros-ctl libs           list host dylibs mapped by AROSBootstrap (path + version)
#   aros-ctl wait [SECS]    sleep, letting AROS run/render (default 1)
set -u

# --- Relocatable paths -----------------------------------------------------
# Resolve this script's own dir (following symlinks) -> repo root, so the
# in-repo artifacts are found wherever the checkout lives. Each is overridable.
SELF="${BASH_SOURCE[0]}"
while [ -h "$SELF" ]; do
    d="$(cd -P "$(dirname "$SELF")" >/dev/null 2>&1 && pwd)"
    SELF="$(readlink "$SELF")"; case "$SELF" in /*) ;; *) SELF="$d/$SELF";; esac
done
HERE="$(cd -P "$(dirname "$SELF")" >/dev/null 2>&1 && pwd)"   # .../graft
ROOT="$(cd "$HERE/.." >/dev/null 2>&1 && pwd)"                # repo root

: "${AROS_HOST_CONF:=$HOME/Library/Application Support/AROS/aros-host.conf}"
export AROS_HOST_CONF
[ -f "$HERE/aros-host-conf.sh" ] && . "$HERE/aros-host-conf.sh"

# cocoametal host shim (built into the repo's build/) and the entitlements that
# travel beside this script. Override AROS_CTL_DYLIB / AROS_CTL_ENT if relocated.
DYLIB_SRC="${AROS_CTL_DYLIB:-$ROOT/build/cocoametal.dylib}"
ENT="${AROS_CTL_ENT:-$HERE/aros-host.entitlements.plist}"

# The AROS boot dir (AROSBootstrap + .conf) is a BUILD OUTPUT that lives outside
# the repo, so we discover it lazily (only `run` needs it): $AROS_CTL_BOOTD wins,
# else the canonical build dir ($BUILD, default /tmp/arosbuild — see
# build-darwin-aarch64.sh), else an in-repo staging dir, else the newest matching
# scratchpad build. Newest AROSBootstrap by mtime breaks ties.
find_bootd() {
    if [ -n "${AROS_CTL_BOOTD:-}" ]; then printf '%s\n' "$AROS_CTL_BOOTD"; return; fi
    local d t best="" bt=0
    local restore; restore="$(shopt -p nullglob)"; shopt -s nullglob   # unmatched globs vanish
    for d in \
        "${BUILD:-/tmp/arosbuild}/bin/darwin-aarch64/AROS/boot/darwin" \
        "$ROOT/build/AROS/boot/darwin" \
        /private/tmp/claude-*/*/*/scratchpad/arosbuild/bin/darwin-aarch64/AROS/boot/darwin \
        /tmp/*/bin/darwin-aarch64/AROS/boot/darwin ; do
        [ -x "$d/AROSBootstrap" ] || continue
        t="$(stat -f %m "$d/AROSBootstrap" 2>/dev/null || echo 0)"
        [ "$t" -ge "$bt" ] && { bt="$t"; best="$d"; }
    done
    $restore
    printf '%s\n' "$best"
}

# Overridable so parallel sessions (e.g. a host-volume test) don't fight over one
# window: set AROS_CTL_FIFO/LOG/PIDF to isolate an instance.
FIFO="${AROS_CTL_FIFO:-/tmp/aros-cm.ctl}"
LOG="${AROS_CTL_LOG:-/tmp/aros-window.log}"
PIDF="${AROS_CTL_PIDF:-/tmp/aros-cm.pid}"

ctl() { [ -p "$FIFO" ] && printf '%s\n' "$*" > "$FIFO"; }

write_startup_sequence() {
    local startup="$AROS/S/Startup-Sequence"

    if [ -n "${AROS_CTL_STARTUP_FILE:-}" ]; then
        cp -f "$AROS_CTL_STARTUP_FILE" "$startup"
    else
        case "${AROS_CTL_STARTUP_MODE:-console}" in
        desktop|wanderer)
            # A compact desktop boot path. The stock Startup-Sequence does much
            # more, but these are the pieces Wanderer expects before it starts.
            {
                printf '%s\n' \
                    'Version' \
                    'FailAt 21' \
                    'If NOT EXISTS "RAM:Clipboards"' \
                    '    MakeDir "RAM:Clipboards"' \
                    'EndIf' \
                    'If NOT EXISTS "RAM:T"' \
                    '    MakeDir "RAM:T"' \
                    'EndIf' \
                    'If NOT EXISTS "RAM:ENV"' \
                    '    MakeDir "RAM:ENV"' \
                    '    Assign "ENV:" "RAM:ENV"' \
                    'EndIf' \
                    'Assign "T:" "RAM:T"' \
                    'Assign "CLIPS:" "SYS:clips"' \
                    'Assign "KEYMAPS:" "DEVS:Keymaps"' \
                    'Assign "LOCALE:" "SYS:Locale"' \
                    'Assign "LIBS:" "SYS:Classes" ADD' \
                    'Assign "HELP:" "LOCALE:Help" DEFER' \
                    'Assign "IMAGES:" "SYS:System/Images" DEFER' \
                    'Assign "WANDERER:" "SYS:System/Wanderer" DEFER' \
                    'Assign "THEMES:" "SYS:Prefs/Presets/Themes" >NIL:' \
                    'Assign "THEME:" "THEMES:AROSDefault"' \
                    'If EXISTS "THEME:Images"' \
                    '    Assign "IMAGES:" "THEME:Images" PREPEND' \
                    'EndIf' \
                    'Path "C:" "SYS:System" "S:" "SYS:Prefs" QUIET' \
                    'If EXISTS "SYS:Fonts"' \
                    '    Assign "FONTS:" "SYS:Fonts"' \
                    'EndIf' \
                    'If EXISTS "SYS:Tools"' \
                    '    Path "SYS:Tools" QUIET ADD' \
                    'EndIf' \
                    'If EXISTS "SYS:Utilities"' \
                    '    Path "SYS:Utilities" QUIET ADD' \
                    'EndIf' \
                    'If EXISTS "C:AddDataTypes"' \
                    '    AddDataTypes REFRESH QUIET' \
                    'EndIf' \
                    'If EXISTS "C:IPrefs"' \
                    '    IPrefs' \
                    'EndIf' \
                    'Run <NIL: >NIL: QUIET ConClip' \
                    'If EXISTS "WANDERER:Wanderer"' \
                    '    Run <NIL: >NIL: QUIET WANDERER:Wanderer' \
                    '    Wait 2' \
                    '    EndCLI' \
                    'EndIf'
            } > "$startup"
            ;;
        console)
            # Startup-sequence: version, then bring up the console<->system
            # clipboard bridge. CLIPS: -> a host-visible dir (so a copied clip
            # lands as a readable file), then ConClip (the con-handler/string-
            # gadget edithook + rendezvous port) so RAmiga+C/V in the console
            # route through clipboard.device.
            printf 'Version\nAssign CLIPS: SYS:clips\nRun ConClip\n' > "$startup"
            ;;
        *)
            echo "aros-ctl: unknown AROS_CTL_STARTUP_MODE=${AROS_CTL_STARTUP_MODE}" >&2
            exit 1
            ;;
        esac
    fi

    [ -n "${AROS_CTL_STARTUP_EXTRA:-}" ] && printf '%s\n' "$AROS_CTL_STARTUP_EXTRA" \
        >> "$startup"
    return 0
}

# char -> "VK SHIFT"  (macOS virtual keycodes). SHIFT=1 means hold left-shift.
char2vk() {
    case "$1" in
        a) echo "0 0";;  b) echo "11 0";; c) echo "8 0";;  d) echo "2 0";;
        e) echo "14 0";; f) echo "3 0";;  g) echo "5 0";;  h) echo "4 0";;
        i) echo "34 0";; j) echo "38 0";; k) echo "40 0";; l) echo "37 0";;
        m) echo "46 0";; n) echo "45 0";; o) echo "31 0";; p) echo "35 0";;
        q) echo "12 0";; r) echo "15 0";; s) echo "1 0";;  t) echo "17 0";;
        u) echo "32 0";; v) echo "9 0";;  w) echo "13 0";; x) echo "7 0";;
        y) echo "16 0";; z) echo "6 0";;
        0) echo "29 0";; 1) echo "18 0";; 2) echo "19 0";; 3) echo "20 0";;
        4) echo "21 0";; 5) echo "23 0";; 6) echo "22 0";; 7) echo "26 0";;
        8) echo "28 0";; 9) echo "25 0";;
        ' ') echo "49 0";; '.') echo "47 0";; ',') echo "43 0";; '/') echo "44 0";;
        ';') echo "41 0";; "'") echo "39 0";; '-') echo "27 0";; '=') echo "24 0";;
        '[') echo "33 0";; ']') echo "30 0";; '\') echo "42 0";; '`') echo "50 0";;
        ':') echo "41 1";; '_') echo "27 1";; '+') echo "24 1";; '?') echo "44 1";;
        '!') echo "18 1";; '@') echo "19 1";; '#') echo "20 1";; '$') echo "21 1";;
        '%') echo "23 1";; '^') echo "22 1";; '&') echo "26 1";; '*') echo "28 1";;
        '(') echo "25 1";; ')') echo "29 1";; '"') echo "39 1";;
        [A-Z]) lc=$(echo "$1" | tr 'A-Z' 'a-z'); echo "$(char2vk "$lc" | cut -d' ' -f1) 1";;
        *) echo "";;
    esac
}

LSHIFT=56   # macOS kVK_Shift
LCMD=55     # macOS kVK_Command
CMOD=8      # CM_MOD_CMD

cmd="${1:-}"; [ $# -gt 0 ] && shift

case "$cmd" in
run)
    BOOTD="$(find_bootd)"
    if [ -z "$BOOTD" ] || [ ! -x "$BOOTD/AROSBootstrap" ]; then
        echo "aros-ctl: no AROSBootstrap found." >&2
        echo "  point AROS_CTL_BOOTD at <build>/bin/darwin-aarch64/AROS/boot/darwin," >&2
        echo "  or build one with graft/build-darwin-aarch64.sh (BUILD defaults to /tmp/arosbuild)." >&2
        exit 1
    fi
    echo "boot dir: $BOOTD" >&2
    AROS="$(cd "$BOOTD/../.." && pwd)"
    artifact_line() {
        local label="$1" path="$2" stamp hash
        [ -e "$path" ] || return 0
        stamp="$(stat -f '%Sm' -t '%Y-%m-%d %H:%M:%S' "$path" 2>/dev/null || echo '?')"
        hash="$(shasum -a 256 "$path" 2>/dev/null | awk '{print substr($1,1,12)}')"
        echo "$label ${hash:-????????????} $stamp" >&2
    }
    mkdir -p "$HOME/lib"; [ -f "$DYLIB_SRC" ] && cp -f "$DYLIB_SRC" "$HOME/lib/cocoametal.dylib"
    # Clipboard bridge host shim: the AROS sync task loads it by bare name via
    # hostlib.resource, so it must sit in ~/lib like cocoametal.dylib. Without it
    # the bridge starts but silently no-ops (no NSPasteboard access).
    [ -f "$ROOT/build/libpasteboard.dylib" ] && cp -f "$ROOT/build/libpasteboard.dylib" "$HOME/lib/libpasteboard.dylib"
    [ -f "$ROOT/hosted/cocoametal/settings.json" ] && cp -f "$ROOT/hosted/cocoametal/settings.json" "$HOME/lib/settings.json"
    mkdir -p "$AROS/Devs/Monitors"
    [ -f "$AROS/Storage/Monitors/Cocoa" ] && cp -f "$AROS/Storage/Monitors/Cocoa" "$AROS/Devs/Monitors/Cocoa"
    rm -f "$AROS/Devs/Monitors/headless"
    mkdir -p "$AROS/clips"   # CLIPS: target (host-side, so the AROS startup-seq needs no MakeDir)
    if [ -z "${AROS_HOST_VOLUME:-}" ]; then
        HOST_FOLDER="${AROS_CTL_HOST_FOLDER:-$HOME/AROS/Shared}"
        mkdir -p "$HOST_FOLDER"
        [ -e "$HOST_FOLDER/ReadMe" ] || \
            printf 'Files here show up in AROS as MacRO: (read-only) and MacRW: (read/write).\n' \
                > "$HOST_FOLDER/ReadMe"
        AROS_HOST_VOLUME="MacRO:$HOST_FOLDER
MacRW:$HOST_FOLDER;WRITE"
    fi
    grep -v '^arguments ' "$BOOTD/AROSBootstrap.conf" > "$BOOTD/AROSBootstrap.conf.tmp" 2>/dev/null \
        && mv "$BOOTD/AROSBootstrap.conf.tmp" "$BOOTD/AROSBootstrap.conf"
    if [ -n "${AROS_HOST_MEMORY:-}" ]; then
        grep -v '^memory ' "$BOOTD/AROSBootstrap.conf" > "$BOOTD/AROSBootstrap.conf.tmp" 2>/dev/null \
            || cp "$BOOTD/AROSBootstrap.conf" "$BOOTD/AROSBootstrap.conf.tmp"
        printf 'memory %s\n' "$AROS_HOST_MEMORY" >> "$BOOTD/AROSBootstrap.conf.tmp"
        mv "$BOOTD/AROSBootstrap.conf.tmp" "$BOOTD/AROSBootstrap.conf"
    fi
    for M in Devs/shell.resource Devs/task.resource \
        Devs/Drivers/hiddclass.hidd Devs/Drivers/gfx.hidd \
        Devs/Drivers/inputclass.hidd Devs/Drivers/keyboard.hidd Devs/Drivers/mouse.hidd \
        Devs/console.device Devs/input.device Devs/keyboard.device Devs/gameport.device \
        Devs/clipboard.device Devs/timer.device \
        Libs/keymap.library Libs/graphics.library Libs/layers.library \
        Libs/intuition.library Libs/gadtools.library Libs/iffparse.library \
        Libs/asl.library Libs/commodities.library Libs/cybergraphics.library \
        Libs/coolimages.library Libs/datatypes.library Libs/locale.library \
        Libs/muimaster.library Libs/rexxsyslib.library Libs/stdc.library \
        L/con-handler ; do
        if [ -e "$AROS/$M" ] && ! grep -q "/$M\$" "$BOOTD/AROSBootstrap.conf"; then
            echo "module $AROS/$M" >> "$BOOTD/AROSBootstrap.conf"
        fi
    done
    write_startup_sequence
    # Present as "Daedalos" in the menu bar / Dock — macOS names a non-bundled app
    # by its executable filename, so run a signed copy named Daedalos. The discovered
    # AROSBootstrap stays the build artifact we copy from (and the .conf keeps its name).
    cp -f "$BOOTD/AROSBootstrap" "$BOOTD/Daedalos"
    [ -f "$ENT" ] && codesign -s - -f -o runtime --entitlements "$ENT" "$BOOTD/Daedalos" 2>/dev/null \
                  || codesign -s - -f "$BOOTD/Daedalos" 2>/dev/null
    artifact_line "AROSBootstrap" "$BOOTD/AROSBootstrap"
    artifact_line "emul-handler" "$BOOTD/L/emul-handler"
    artifact_line "Cocoa monitor" "$AROS/Devs/Monitors/Cocoa"
    artifact_line "locale.library" "$AROS/Libs/locale.library"
    artifact_line "timer.device" "$BOOTD/Devs/timer.device"
    [ -e "$BOOTD/Devs/timer.device" ] || artifact_line "timer.device" "$AROS/Devs/timer.device"
    artifact_line "task.resource" "$AROS/Devs/task.resource"
    artifact_line "cybergraphics.library" "$AROS/Libs/cybergraphics.library"
    artifact_line "coolimages.library" "$AROS/Libs/coolimages.library"
    artifact_line "muimaster.library" "$AROS/Libs/muimaster.library"
    artifact_line "stdc.library" "$AROS/Libs/stdc.library"
    artifact_line "posixc.library" "$AROS/Libs/posixc.library"
    artifact_line "png.library" "$AROS/Libs/png.library"
    artifact_line "picture.datatype" "$AROS/Classes/DataTypes/picture.datatype"
    artifact_line "png.datatype" "$AROS/Classes/DataTypes/png.datatype"
    artifact_line "TestLib" "$AROS/C/TestLib"
    artifact_line "LoadMatrix" "$AROS/C/LoadMatrix"
    artifact_line "Wanderer" "$AROS/System/Wanderer/Wanderer"
    rm -f "$FIFO"; mkfifo -m 600 "$FIFO"
    ( cd "$BOOTD" && exec nohup env AROS_DARWIN_THREADED=1 AROS_CM_CONTROL="$FIFO" \
        DYLD_FALLBACK_LIBRARY_PATH="$HOME/lib" \
        AROS_HOST_VOLUME="$AROS_HOST_VOLUME" \
        AROS_SETTINGS_SCHEMA="$HOME/lib/settings.json" \
        ./Daedalos -c "$BOOTD/AROSBootstrap.conf" </dev/null >"$LOG" 2>&1 ) &
    echo $! > "$PIDF"
    echo "AROS pid $(cat "$PIDF")  log=$LOG  control=$FIFO"
    ;;
stop)
    stopped=0
    if [ -f "$PIDF" ]; then
        pid="$(cat "$PIDF" 2>/dev/null)"
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
            for _ in 1 2 3 4 5; do
                kill -0 "$pid" 2>/dev/null || break
                sleep 0.2
            done
            kill -0 "$pid" 2>/dev/null && kill -KILL "$pid" 2>/dev/null
            stopped=1
        fi
    fi
    if [ "$stopped" = 0 ]; then
        BOOTD="$(find_bootd)"
        if [ -n "$BOOTD" ]; then
            ps -axo pid=,command= | while read -r pid command; do
                case "$command" in
                    *"/Daedalos -c $BOOTD/AROSBootstrap.conf"|*"./Daedalos -c $BOOTD/AROSBootstrap.conf"|*"/AROSBootstrap -c $BOOTD/AROSBootstrap.conf"|*"./AROSBootstrap -c $BOOTD/AROSBootstrap.conf")
                        kill "$pid" 2>/dev/null
                        ;;
                esac
            done
        fi
    fi
    rm -f "$PIDF" "$FIFO"
    echo "stopped"
    ;;
key)    ctl "K ${1:-0} ${2:-1} ${3:-0}";;
cmdc)   ctl "K $LCMD 1 $CMOD"; ctl "K 8 1 $CMOD"; ctl "K 8 0 $CMOD"; ctl "K $LCMD 0 0";;
cmdv)   ctl "K $LCMD 1 $CMOD"; ctl "K 9 1 $CMOD"; ctl "K 9 0 $CMOD"; ctl "K $LCMD 0 0";;
button) ctl "B ${1:-0} ${2:-1}";;
mouse)  ctl "M ${1:-0} ${2:-0}";;
click)  b="${1:-0}"; ctl "B $b 1"; ctl "B $b 0";;
enter)  ctl "K 36 1"; ctl "K 36 0";;
type)
    text="$*"
    for (( i=0; i<${#text}; i++ )); do
        ch="${text:$i:1}"
        vs="$(char2vk "$ch")"; [ -z "$vs" ] && continue
        vk="${vs% *}"; sh="${vs#* }"
        [ "$sh" = "1" ] && ctl "K $LSHIFT 1"
        ctl "K $vk 1"; ctl "K $vk 0"
        [ "$sh" = "1" ] && ctl "K $LSHIFT 0"
    done
    ;;
shot)
    out="${1:-/tmp/aros-shot.png}"
    ppm="${out%.png}.ppm"
    ctl "S $ppm"
    sleep 0.4
    if [ "${out##*.}" = "png" ] && [ -f "$ppm" ]; then
        sips -s format png "$ppm" --out "$out" >/dev/null 2>&1 && echo "shot -> $out" || echo "shot -> $ppm (sips failed)"
    else
        echo "shot -> $ppm"
    fi
    ;;
log)    tail -n "${1:-40}" "$LOG" 2>/dev/null;;
crash)  grep -nE "Trap signal|Alert|stack limits|Module |Function |supervisor mode|Privilege" "$LOG" 2>/dev/null | head -40;;
libs)
    # Host (macOS) dylibs mapped into the AROS process — path + version. Verifies
    # which host shim actually loaded and from where (e.g. ~/lib/cocoametal.dylib).
    # System libs in the dyld shared cache aren't separate files, so they show up
    # under "(dyld shared cache)" rather than individually — that's expected.
    # For AROS-side libraries (graphics/intuition/… name+version), use the AROS
    # `LibList` C: command inside the shell instead (those aren't host dylibs).
    pid="$(cat "$PIDF" 2>/dev/null)"
    kill -0 "$pid" 2>/dev/null || pid="$(pgrep -n Daedalos 2>/dev/null)"
    [ -n "$pid" ] || { echo "no running Daedalos (start it with: aros-ctl run)" >&2; exit 1; }
    echo "# host dylibs mapped by Daedalos (pid $pid):"
    vmmap "$pid" 2>/dev/null | grep -oE '/[^[:space:]]+\.dylib' | sort -u | while read -r dy; do
        # current version from the dylib's own load command (file-backed libs only;
        # shared-cache libs have no on-disk file, so just show the path).
        ver="$(otool -l "$dy" 2>/dev/null | awk '/LC_ID_DYLIB/{f=1} f&&/current version/{print $3; exit}')"
        printf '  %s%s\n' "$dy" "${ver:+  (v$ver)}"
    done
    ;;
wait)   sleep "${1:-1}";;
*)
    echo "usage: aros-ctl {run|stop|type|enter|key|cmdc|cmdv|mouse|click|button|shot|log|crash|libs|wait}" >&2
    exit 1;;
esac
