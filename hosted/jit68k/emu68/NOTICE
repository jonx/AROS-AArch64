  M68k_MOVE.c     <- Emu68 src/M68k_MOVE.c      (move / moveq)
  M68k_MULDIV.c   <- Emu68 src/M68k_MULDIV.c    (MUL/DIV bodies; EMIT_MULS_W etc.)
  M68k.h          <- Emu68 include/M68k.h       (struct M68KState, VECTOR_*, SR_*)
  support.h       <- Emu68 include/support.h    (BE/LE helpers, decls)
  cache.h         <- Emu68 include/cache.h      (enum CacheType, cache_read_* sigs)
