<?xml version="1.0" encoding="UTF-8"?>
<!--
  jit68k.entitlements.plist — the minimal entitlement set that lets a
  HARDENED-RUNTIME signed binary use the MAP_JIT executable-memory layer
  (mmap(MAP_JIT) + pthread_jit_write_protect_np). [J1] / R-JIT-ENTITLE.

  Empirically pinned on this Mac (macOS 26.5, Apple silicon):
    - default linker ad-hoc signature (NO hardened runtime): MAP_JIT already works,
      this plist is NOT needed.
    - hardened runtime (codesign -o runtime) WITHOUT this entitlement:
      mmap(MAP_JIT) fails EINVAL(22).
    - hardened runtime WITH com.apple.security.cs.allow-jit: MAP_JIT works again.
  So allow-jit is the single key required, and only once the hardened runtime is on.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
