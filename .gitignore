# build + run artifacts (regenerated by the harness every loop)
/build/
/run/
/crash/

# Rust / Cargo build output (machine-specific fingerprints; each crate's
# build script regenerates it).
**/target/


# Compiled intermediates (regenerable; some embed the local build path in
# debug info). The shader ships embedded as cmshader_metallib.h; .air/.metallib
# are xcrun intermediates.
*.air
*.metallib
*.dSYM/

# Compiled probe artifacts. The run68k sample corpus under
# hosted/jit68k/apps68k/bin/ is intentionally kept (it does not embed paths).
hosted/jit68k/rust68k/bin/allocprobe.exe
hosted/jit68k/rust68k/bin/vecsum.exe
hosted/jit68k/rust68k/bin/vecsum_inclusive.exe
hosted/jit68k/rust68k/memprobe/mp_nightly-*.exe
hosted/jit68k/rust68k/std68k-probe/std68k.exe
hosted/jit68k/rust68k/std68k-probe/std68k.exe.demo

# Verification screenshots (regenerated by the smoke harnesses; kept local).
docs/features/bsdsocket-net/*-proof.png

# Raw icon source art (local only; the derived Macaros-1024.png + .icns are
# committed, and make-macaron-icon.sh accepts any source image as $1).
hosted/cocoametal/Macaros-source.png

# macOS
.DS_Store

# editors
.idea/
.vscode/
*.swp
*~
